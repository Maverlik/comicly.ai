APP_NAME=Comicly API
APP_ENV=local
APP_DEBUG=false
DATABASE_URL=postgresql+asyncpg://comicly:comicly@localhost:5432/comicly
# Production runtime should use the Neon pooled URL in async SQLAlchemy form:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-name-pooler.region.aws.neon.tech/dbname?ssl=require

# Alembic migrations may use a direct, non-pooled Neon URL.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://user:password@ep-name.region.aws.neon.tech/dbname?ssl=require
# DATABASE_DIRECT_URL=postgresql+asyncpg://user:password@ep-name.region.aws.neon.tech/dbname?ssl=require

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FULL_PAGE_GENERATION_COST=20
SCENE_REGENERATION_COST=4
STARTER_COINS=100

# Later-phase reference only. These are intentionally not required by startup.
# SESSION_SECRET=
# APP_URL=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# OPENROUTER_API_KEY=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
