APP_NAME=Comicly API
APP_ENV=local
APP_DEBUG=false

# Local development uses Docker Compose Postgres.
DATABASE_URL=postgresql+asyncpg://comicly:comicly@localhost:5432/comicly
# Production runtime should use the Neon pooled URL in async SQLAlchemy form:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-name-pooler.region.aws.neon.tech/dbname?ssl=require

# Alembic migrations may use a direct, non-pooled Neon URL.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://user:password@ep-name.region.aws.neon.tech/dbname?ssl=require
# DATABASE_DIRECT_URL=postgresql+asyncpg://user:password@ep-name.region.aws.neon.tech/dbname?ssl=require

# Production should include https://comicly.ai and https://www.comicly.ai.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FULL_PAGE_GENERATION_COST=20
SCENE_REGENERATION_COST=4
STARTER_COINS=100

SESSION_SECRET=change-me-in-production
FRONTEND_CREATOR_URL=https://comicly.ai/create.html
SESSION_COOKIE_NAME=comicly_session
# Production API cookies for api.comicly.ai can use .comicly.ai when frontend and API share the parent domain.
# SESSION_COOKIE_DOMAIN=.comicly.ai
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_LIFETIME_DAYS=30

# OAuth provider credentials are optional for app startup and required only for live login routes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# OAuth callback URLs to register with providers:
# https://api.comicly.ai/api/v1/auth/google/callback
# https://api.comicly.ai/api/v1/auth/yandex/callback
# Local callback URLs:
# http://localhost:8000/api/v1/auth/google/callback
# http://localhost:8000/api/v1/auth/yandex/callback

# AI provider and storage secrets are optional for app startup, but required for live generation.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://comicly.ai
OPENROUTER_APP_NAME=comicly.ai
OPENROUTER_DEFAULT_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_DEFAULT_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_ALLOWED_IMAGE_MODELS=bytedance-seed/seedream-4.5,google/gemini-3-pro-image-preview,openai/gpt-5.4-image-2
OPENROUTER_IMAGE_ASPECT_RATIO=1:1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=60
BLOB_READ_WRITE_TOKEN=

# YooKassa checkout and webhook fulfillment. Test shop credentials belong only
# in local `.env` or Vercel environment variables, never in committed files.
YOOKASSA_SHOP_ID=
YOOKASSA_API_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_REQUEST_TIMEOUT_SECONDS=20
YOOKASSA_RETURN_URL=https://comicly-ai.vercel.app/pricing.html?payment=return
# Production defaults to YooKassa documented webhook source ranges.
# Disable only for local tests or when an upstream trusted proxy handles this.
YOOKASSA_WEBHOOK_IP_CHECK_ENABLED=true
YOOKASSA_WEBHOOK_IP_ALLOWLIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35,77.75.154.128/25,2a02:5180::/32

# MVP security controls. In-process rate limiting is best-effort on serverless.
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
