APP_NAME=Comicly API
APP_ENV=production
APP_DEBUG=false

# Use an external managed PostgreSQL database, not a database container on the VPS.
DATABASE_URL=postgresql+asyncpg://user:password@postgres-host:5432/comicly?ssl=require
MIGRATION_DATABASE_URL=postgresql+asyncpg://user:password@postgres-host:5432/comicly?ssl=require

CORS_ORIGINS=https://comicly-ai.ru
FULL_PAGE_GENERATION_COST=20
SCENE_REGENERATION_COST=4
STARTER_COINS=100

SESSION_SECRET=replace-with-long-random-secret
FRONTEND_CREATOR_URL=https://comicly-ai.ru/create.html
OAUTH_CALLBACK_BASE_URL=https://comicly-ai.ru
SESSION_COOKIE_NAME=comicly_session
SESSION_COOKIE_DOMAIN=.comicly-ai.ru
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_LIFETIME_DAYS=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://comicly-ai.ru
OPENROUTER_APP_NAME=comicly-ai.ru
OPENROUTER_DEFAULT_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_DEFAULT_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_ALLOWED_IMAGE_MODELS=bytedance-seed/seedream-4.5,google/gemini-3-pro-image-preview,openai/gpt-5.4-image-2
OPENROUTER_IMAGE_ASPECT_RATIO=1:1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=60

# Generated images are stored in S3-compatible object storage.
S3_ENDPOINT_URL=https://s3.example.com
S3_REGION=ru-1
S3_BUCKET=comicly-generated
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://cdn.example.com/comicly-generated
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_READ_ACL=true

YOOKASSA_SHOP_ID=
YOOKASSA_API_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_REQUEST_TIMEOUT_SECONDS=20
YOOKASSA_RETURN_URL=https://comicly-ai.ru/pricing.html?payment=return
YOOKASSA_WEBHOOK_IP_CHECK_ENABLED=true
YOOKASSA_WEBHOOK_IP_ALLOWLIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35,77.75.154.128/25,2a02:5180::/32

SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
