# Скопируйте этот файл в .env и вставьте свой ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Модель для генерации изображений страниц комикса.
# Рекомендация: google/gemini-2.5-flash-image-preview (быстрая, поддерживает modalities=["image","text"])
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview

# Модель для текстовых задач (улучшение сюжета, диалоги, подписи, раскадровка)
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash

# Формат страницы комикса: 1:1, 3:4, 4:3 и т.д.
OPENROUTER_IMAGE_ASPECT_RATIO=3:4

# Метаданные для OpenRouter (для кабинета usage)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=comicly.ai
