# Root static frontend / legacy local Node server example.
#
# The production FastAPI backend uses backend/.env.example as the source of truth.
# Do not put real secrets in this file or commit local .env files.

PORT=3000

# Optional static frontend build/runtime override. Leave empty when frontend and
# backend are served from the same origin through Caddy.
COMICLY_API_BASE_URL=

# Legacy local Node OpenRouter proxy settings. The production creator calls
# /api/v1 on the production domain through the FastAPI backend instead.
OPENROUTER_API_KEY=sk-or-v1-placeholder
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=comicly-ai.ru
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_IMAGE_ASPECT_RATIO=3:4
