{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://comicly-backend.vercel.app/api/v1/:path*"
    },
    {
      "source": "/health",
      "destination": "https://comicly-backend.vercel.app/health"
    },
    {
      "source": "/ready",
      "destination": "https://comicly-backend.vercel.app/ready"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
